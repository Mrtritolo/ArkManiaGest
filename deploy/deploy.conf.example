# =============================================================================
# deploy.conf.example — Deploy configuration template
# =============================================================================
# This is the SINGLE SOURCE OF TRUTH template for deploy-time parameters.
#
# FIRST USE:
#   1. Copy this file:   cp deploy/deploy.conf.example deploy/deploy.conf
#   2. Edit deploy/deploy.conf and fill in real values.
#   3. deploy/deploy.conf is gitignored — it stays on your dev PC only.
#
# Every .sh / .ps1 script in deploy/ sources deploy.conf at runtime.  When
# the file is missing they fall back to this template and print a warning.
# =============================================================================

# --- Target server (used by the PowerShell scripts on the dev PC) ---
DEPLOY_SERVER="root@YOUR_SERVER_IP"

# --- SSH authentication (optional, used by update-panel.{sh,ps1} +
#     update-remote.ps1) ---
#
# When you log in to the panel host with a dedicated key rather than the
# default ~/.ssh/id_* one, set SSH_KEY_PATH to its absolute path.  The
# scripts will pass `-i $SSH_KEY_PATH -o IdentitiesOnly=yes` to every ssh /
# scp invocation, and `-o BatchMode=yes` so a misconfigured key fails fast
# instead of dropping you into a password prompt mid-update.
#
# Leave empty to let OpenSSH search ~/.ssh/ + ssh-agent as usual.
#
# On Windows use forward slashes or quoted backslashes, e.g.:
#     SSH_KEY_PATH="C:/Users/Alessio/.ssh/id_arkmaniagest"
SSH_KEY_PATH=""

# Override the SSH user / port when DEPLOY_SERVER doesn't already encode
# them as `user@host` / when the host listens on a non-default port.
SSH_USER=""
SSH_PORT=22

# --- Domain & SSL ---
DOMAIN="your-domain.example.com"
SSL_EMAIL="admin@example.com"

# --- Application paths on the server ---
APP_DIR="/opt/arkmaniagest"
APP_USER="arkmania"
LOG_DIR="/var/log/arkmaniagest"
BACKUP_DIR="/opt/arkmaniagest-backups"

# --- GeoIP country allowlist (ISO 3166-1 alpha-2 codes) ---
# Leave empty to disable geo-blocking entirely.
GEOIP_ALLOWED_COUNTRIES="IT CH"

# --- IP whitelist for GeoIP bypass (space-separated CIDR blocks) ---
# These IPs bypass the geo-block regardless of country.
# Localhost (127.0.0.1, ::1) is always included automatically.
# Add your admin / office / monitoring IPs here (in the local deploy.conf).
GEOIP_WHITELIST_IPS=""

# --- Public API: CORS origin for the public-facing website ---
# The /api/v1/public/ endpoints serve data to this origin.
# Leave empty if no public website integration is needed.
PUBLIC_SITE_ORIGIN=""

# --- Cron sync secret (must match CRON_SECRET in backend .env) ---
# Leave empty to read from the backend .env at runtime (recommended).
CRON_SYNC_SECRET=""
