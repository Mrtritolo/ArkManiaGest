# =============================================================================
# .gitignore — ArkManiaGest
# =============================================================================
# Keep the repository minimal: only source code, build configuration, and the
# deploy tooling.  Secrets, runtime state, build artifacts, editor metadata,
# and external reference material stay local.
# =============================================================================

# --- Python (backend) ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
venv/
.venv/
env/

# --- Node / Vite (frontend) ---
node_modules/
frontend/dist/
.vite/
*.tsbuildinfo

# --- Secrets & environment ---
.env
.env.local
.env.*.local
*.vault
# Runtime data (local sqlite, cache, ecc.)
data/
backend/data/
# Local deploy config (real server IPs, admin IP whitelist, cron secret) —
# a sanitised template lives in deploy/deploy.conf.example.
deploy/deploy.conf
deploy/deploy.local.conf

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*

# --- OS artifacts ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Log / backup locali ---
logs/
*.log
*.bak
*.backup
*~$
backup*/

# --- SSH / Key material ---
*.pem
*.key
*.crt
id_rsa*
id_ed25519*
*.ppk

# --- Claude Code session-specific ---
# Per-developer / per-tool state — never share via git.
.claude/

# --- File / cartelle deprecate (dev-only) ---
_deprecated/
config/

# --- Sorgenti di riferimento esterni (clonati localmente, non vanno su git) ---
# Usato per tenere una copia del repo POK-ASA-Server come riferimento per
# il template dei docker-compose e gli script bash di gestione istanze.
reference/

# --- Dataset Dododex import (grandi JSON di dati di gioco) ---
deploy/imports/s-dino-variants.json
deploy/imports/hair-chairs-items.json
deploy/imports/dododex-skins-test.json
deploy/imports/_parse_dododex_items.py

# --- Archivi temporanei di deploy ---
/*.tar.gz
/*.zip

# --- Release build artefacts (produced by deploy/package-release.ps1) ---
release-build/

# --- One-shot release notes (consumed by deploy/maintainer/release.ps1 -NotesFile) ---
# Hand-written per release, fed into the CHANGELOG, then deleted.  Never
# committed -- the canonical record lives in CHANGELOG.md.
next-release-notes.md
release-notes-*.md
